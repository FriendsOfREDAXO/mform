mform_migration_batch_slices = {0} Slice(s)
mform_migration_batch_slot = Repeater-Slot (value-Spalte)
mform_migration_batch_slot_note = Spalte, in der die MBlock-Daten liegen. value1 entspricht Slot 1. Erlaubt sind 1 bis 20.
mform_migration_batch_dryrun = Probelauf starten
mform_migration_batch_summary = {0} Slice(s) geprueft, {1} mit Aenderung, {2} mit Warnungen. Quelle: Spalte {3}.
